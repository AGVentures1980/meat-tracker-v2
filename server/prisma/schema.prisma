  storeId                Int
  supplierId             String?
  documentType           SupplierDocType
  externalDocumentNumber String?
  issueDate              DateTime?
  sourceChannel          String   @default("UPLOAD")
  rawPayload             Json?
  parsedStatus           DocParsedStatus @default(CAPTURED)
  confidence             Float    @default(0.0)

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  lines                  SupplierDocumentLine[]

  @@index([storeId])
  @@index([externalDocumentNumber])
}

model SupplierDocumentLine {
  id                 String   @id @default(cuid())
  documentId         String
  supplierItemCode   String?
  qty                Int?
  weight             Float?
  price              Float?

  document           SupplierDocument @relation(fields: [documentId], references: [id])
}

model PosSalesFeed {
  id               String   @id @default(cuid())
  storeId          Int
  businessDate     DateTime
  sourceSystem     String   @default("TOAST")
  transactionRef   String?
  importedAt       DateTime @default(now())

  lines            PosSalesLine[]

  @@index([storeId, businessDate])
}

model PosSalesLine {
  id               String   @id @default(cuid())
  feedId           String
  itemSold         String
  quantity         Float
  modifiers        Json?
  channel          String   @default("DINE_IN")

  feed             PosSalesFeed @relation(fields: [feedId], references: [id])
}

model ReconciliationEvent {
  id               String   @id @default(cuid())
  storeId          Int
  businessDate     DateTime
  status           String   @default("OPEN")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  varianceCases    VarianceCase[]

  @@index([storeId, businessDate])
}

model VarianceCase {
  id                      String   @id @default(cuid())
  reconciliationEventId   String
  type                    String
  severity                VarianceSeverity @default(LOW)
  sourceEntities          Json?
  financialEstimate       Float?
  status                  String   @default("OPEN")
  requiredAction          String?
  assignedRole            String?
  auditTrail              Json?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  reconciliationEvent     ReconciliationEvent @relation(fields: [reconciliationEventId], references: [id])
}

model SupplierIntegritySnapshot {
  id                       String   @id @default(cuid())
  companyId                String
  supplierId               String
  periodStart              DateTime
  periodEnd                DateTime
  weakRuleRate             Float    @default(0.0)
  reviewRate               Float    @default(0.0)
  rejectRate               Float    @default(0.0)
  documentMismatchRate     Float    @default(0.0)
  expectedVsReceivedVariance Float  @default(0.0)
  averageRiskScore         Float    @default(0.0)
  confidenceIndex          Float    @default(1.0)
  degradationTrend         String?

  createdAt                DateTime @default(now())

  @@index([companyId, supplierId, periodEnd])
}

enum PoStatus {
  DRAFT
  ISSUED
  PARTIALLY_FULFILLED
  FULFILLED
  DISPUTED
  CLOSED
}

enum DeliveryStatus {
  PLANNED
  IN_TRANSIT
  ARRIVED
  PARTIALLY_RECEIVED
  RECEIVED
  EXCEPTION
}

enum SupplierDocType {
  INVOICE
  PACKING_LIST
  BILL_OF_LADING
  ASN
  DELIVERY_NOTE
}

enum DocParsedStatus {
  CAPTURED
  PARSED
  VERIFIED
  LINKED
  DISPUTED
}

enum VarianceSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// =======================================================
// BRASA TRANSFORMATION & CONSUMPTION ENGINE (PROMPT 07)
// =======================================================

model ProteinTransformationBatch {
  id                String   @id @default(cuid())
  storeId           Int
  productType       String   // e.g. HAMBURGER, PRIME_RIB_PORTION
  totalInputWeight  Float    @default(0.0)
  totalOutputUnits  Int      @default(0)
  totalOutputWeight Float    @default(0.0)
  yieldPercentage   Float    @default(0.0)
  status            BatchStatus @default(OPEN)

  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  inputs            TransformationInput[]
  outputs           TransformationOutput[]
  consumptionLinks  ConsumptionLink[]

  @@index([storeId, status])
}

model TransformationInput {
  id                 String   @id @default(cuid())
  batchId            String
  sourceProteinBoxId String
  sourceType         InputSourceType // e.g. PRIME_CUT, SCRAP
  weightUsed         Float
  timestamp          DateTime @default(now())

  batch              ProteinTransformationBatch @relation(fields: [batchId], references: [id])
  box                ProteinBox @relation(fields: [sourceProteinBoxId], references: [id])

  @@index([batchId])
  @@index([sourceProteinBoxId])
}

model TransformationOutput {
  id             String   @id @default(cuid())
  batchId        String
  productCode    String   // e.g. HAMBURGER
  unitsProduced  Int
  weightProduced Float
  timestamp      DateTime @default(now())

  batch          ProteinTransformationBatch @relation(fields: [batchId], references: [id])

  @@index([batchId])
}

model ConsumptionLink {
  id             String   @id @default(cuid())
  batchId        String
  posSalesLineId String
  sourceSystem   String   @default("POS") // E.g. POS, OLO
  unitsConsumed  Int
  timestamp      DateTime @default(now())

  batch          ProteinTransformationBatch @relation(fields: [batchId], references: [id])
  salesLine      PosSalesLine @relation(fields: [posSalesLineId], references: [id])

  @@index([batchId])
  @@index([posSalesLineId])
}

enum BatchStatus {
  OPEN
  CLOSED
  RECONCILED
}

enum InputSourceType {
  PRIME_CUT
  SCRAP
}

// =======================================================
// BRASA CONSUMPTION ALLOCATION ENGINE (SUPER PROMPT E2E)
// =======================================================

model ConsumptionAllocationRule {
  id                    String   @id @default(cuid())
  storeId               Int
  productCode           String   // e.g. LAMB_CHOP, BEEF_RIB
  allocationMethod      AllocationMethod
  unitName              String   // e.g. BONE, PORTION
  unitsPerSale          Int      @default(1)
  unitsPerCase          Int      @default(10) // default fallback
  usesLotLevelWeight    Boolean  @default(true)
  fixedPortionWeightLbs Float?   // Nullable, used if FIXED_WEIGHT

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([storeId, productCode])
}

model ProteinConsumptionAllocation {
  id                 String   @id @default(cuid())
  sourceProteinBoxId String?
  sourceScanEventId  String?
  productCode        String
  unitsConsumed      Float
  lbsAllocated       Float
  sourceSystem       String   // POS | OLO
  destinationType    DestinationChannel // SALAO | BAR | DELIVERY
  posSalesLineId     String?

  timestamp          DateTime @default(now())

  box                ProteinBox? @relation(fields: [sourceProteinBoxId], references: [id])
  salesLine          PosSalesLine? @relation(fields: [posSalesLineId], references: [id])

  @@index([sourceProteinBoxId])
  @@index([posSalesLineId])
}

enum AllocationMethod {
  UNIT_BASED
  FIXED_WEIGHT
}

enum DestinationChannel {
  SALAO
  BAR
  DELIVERY
}

// =======================================================
// BRASA EXECUTIVE DASHBOARD ENGINE (PROMPT 09)
// =======================================================

model ExecutiveSnapshotLedger {
  id                    String   @id @default(cuid())
  companyId             Int
  storeId               Int?
  snapshotType          SnapshotType // DAILY | WEEKLY
  businessDate          DateTime
  generatedAt           DateTime @default(now())

  integrityScore        Float
  executiveRiskLevel    String
  weeklyVarianceUSD     Float
  lbsPerGuestDiningRoom Float?

  actionPanelPayload    Json
  metricsVersion        String
  scoreVersion          String?
  policyVersion         String?
  
  isFinal               Boolean  @default(false)
  completenessStatus    String   @default("COMPLETE") // COMPLETE | PARTIAL | INCOMPLETE
  missingSources        String[] // Array of system modules that failed to report
  reasonIfPartial       String?

  @@unique([companyId, storeId, snapshotType, businessDate])
}

model ExecutiveActionDecision {
  id                         String   @id @default(cuid())
  companyId                  Int
  storeId                    Int?
  actionCode                 String
  actionTitle                String
  actionSeverity             String
  financialImpactEstimateUSD Float

  sourceSnapshotId           String?
  sourceMetricVersion        String
  sourceBusinessDate         DateTime?
  
  targetType                 String // STORE | CHANNEL | PRODUCT | SUPPLIER
  targetId                   String // Ref associated to the target
  
  decisionStatus             DecisionStatus @default(OPEN)
  resolutionOutcome          String? // SUCCESS | FALSE_POSITIVE | NO_ACTION_TAKEN
  
  assignedToUserId           String?
  createdBySystem            Boolean @default(true)
  
  viewedAt                   DateTime?
  forwardedAt                DateTime?
  actedByUserId              String?
  actedAt                    DateTime?
  resolvedAt                 DateTime?
  
  notes                      String?

  @@index([companyId, decisionStatus])
}

enum SnapshotType {
  DAILY
  WEEKLY
}

enum DecisionStatus {
  OPEN
  ACKNOWLEDGED
  FORWARDED
  APPROVED
  RESOLVED
  DISMISSED
}

// =======================================================
// BRASA PILOT OPERATIONS COMMAND (PROMPT 11)
// =======================================================

model PilotConfiguration {
  id                 String   @id @default(cuid())
  companyId          Int
  storeId            Int
  status             PilotStatus @default(INACTIVE)
  
  pilotStartDate     DateTime
  pilotEndDate       DateTime?
  
  enabledFeatures    String[] // ['ACTION_PANEL', 'BENTO_GRID_KPI']
  allowedRoles       String[] // ['store_manager', 'director']
  
  successThresholds  Json? // For holding { "avgResolutionTimeSecs": 120 }
  rollbackEnabled    Boolean @default(true)

  @@unique([storeId])
}

model PilotFeedback {
  id                 String   @id @default(cuid())
  companyId          Int
  storeId            Int
  userId             String
  actionDecisionId   String?  // If tied to a specific aborted card
  
  feedbackCategory   FeedbackCategory
  severity           String   // MINOR | MAJOR | BLOCKER
  affectedScreen     String
  comments           String
  
  createdAt          DateTime @default(now())
}

enum PilotStatus {
  ACTIVE
  PAUSED
  ROLLED_BACK
  INACTIVE
  COMPLETED
}

enum FeedbackCategory {
  UX_CONFUSION
  DATA_QUALITY_ISSUE
  OPERATIONAL_PROCESS_GAP
  BUG
  PERFORMANCE_ISSUE
  METRIC_CONFIDENCE_ISSUE
  ADOPTION_BARRIER
}
