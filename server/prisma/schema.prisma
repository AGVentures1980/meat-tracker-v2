  // IMMUTABLE ORIGIN
  raw_input       String @db.Text
  canonical_input String @db.Text // Basis for fingerprint
  fingerprint     String @unique

  // EXPLICIT SCOPING
  tenant_id   String // [NOT NULL]
  store_id    Int?
