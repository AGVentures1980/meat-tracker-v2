  // STATE MACHINE & QUARANTINE
  status             IntakeStatus     @default(RECEIVED)
  quarantine_cause   QuarantineCause?
  quarantine_details Json?

  // PIPELINE VERSIONING
  canonicalizer_version String @default("v1.0.0")
