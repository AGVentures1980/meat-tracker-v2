  estimated_loss_usd Float
  source_of_loss     String?
  baseline_reference String?
  classification     String?
  confidence_score   Float?
  created_at         DateTime @default(now())

  store Store @relation(fields: [store_id], references: [id])
}

model AiYieldInsight {
  id                 String   @id @default(uuid())
  store_id           Int
  date               DateTime @default(now())
  classification     String
  confidence         Float
  explanation        String
  recommended_action String?
  created_at         DateTime @default(now())

  store Store @relation(fields: [store_id], references: [id])
}

model SystemAlert {
  id          String   @id @default(uuid())
  store_id    Int
  severity    String
  source      String
  description String
  raw_data    Json?
  is_resolved Boolean  @default(false)
  created_at  DateTime @default(now())

  store Store @relation(fields: [store_id], references: [id])
}

model IndustryBenchmark {
  id            String   @id @default(uuid())
  cut           String
  yield_min     Float
  yield_max     Float
  trim_loss_min Float
  trim_loss_max Float
  source        String
  version       String
  active_flag   Boolean  @default(true)
  created_at    DateTime @default(now())
}

model BarcodeDecisionLog {
  id                String   @id @default(uuid())
  store_id          Int
  raw_barcode       String
  cleaned_barcode   String   @default("")
  context           String   @default("RECEIVING")
  status            String   @default("UNKNOWN")
  reason_code       String?
  attempted_parsers String[]
  scores            Float[]
  selected_parser   String
  runner_up_parser  String   @default("NONE")
  confidence_gap    Float
  created_at        DateTime @default(now())

  store Store @relation(fields: [store_id], references: [id])

  @@index([store_id, context, status])
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  user_id    String
  token_hash String   @unique // SHA-256 hashed string
  expires_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model PasswordHistory {
  id         Int      @id @default(autoincrement())
  user_id    String
  hash       String // bcrypt
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model VaultFile {
  id         String @id @default(uuid())
  company_id String
  store_id   Int

  document_type String // e.g., 'INVOICE', 'CONTRACT', 'TRAINING_CERT'
  bucket_name   String
  storage_key   String

  original_filename String
  mime_type         String
  size_bytes        Int
  checksum          String?

  is_active     Boolean @default(false)
  upload_status String  @default("PENDING") // PENDING, COMPLETED, QUARANTINED

  uploaded_by_user_id String
  created_at          DateTime  @default(now())
  deleted_at          DateTime?

  company Company @relation(fields: [company_id], references: [id])
  store   Store   @relation(fields: [store_id], references: [id])
  user    User    @relation(fields: [uploaded_by_user_id], references: [id])

  access_logs FileAccessLog[]

  @@index([company_id, store_id])
  @@index([document_type])
  @@index([storage_key])
}

model FileAccessLog {
  id         String @id @default(uuid())
  file_id    String
  user_id    String
  company_id String
  store_id   Int

  action        String // UPLOAD_REQUEST, UPLOAD_COMPLETED, DOWNLOAD_REQUEST, GLOBAL_AUDIT_VIEW
  ip            String
  justification String? // Mandatory for GLOBAL role views

  created_at DateTime @default(now())

  file VaultFile @relation(fields: [file_id], references: [id], onDelete: Cascade)
  user User      @relation(fields: [user_id], references: [id])

  @@index([file_id])
  @@index([user_id])
  @@index([company_id, store_id])
}

model OcrQuarantineQueue {
  id                    String    @id @default(uuid())
  company_id            String?
  store_id              Int
  invoice_number        String?
  invoice_date          DateTime?
  supplier_id           String?
  raw_line_text         String
  normalized_cut_name   String?
  contract_price_per_lb Float?
  invoiced_price_per_lb Float?
  variance_abs          Float?
  variance_pct          Float?
  ocr_confidence        Float
  alert_status          String    @default("PENDING_REVIEW")
  reviewed_by           String?
  reviewed_at           DateTime?
  resolution_notes      String?
  created_at            DateTime  @default(now())

  store Store @relation(fields: [store_id], references: [id])
}

enum DeletionJobStatus {
  ANALYZED
  EXECUTED
  FAILED_HASH_MISMATCH
  FAILED_EXECUTION
  REJECTED
}

model TenantDeletionJob {
  id              String            @id @default(uuid())
  company_id      String
  actor_id        String
  actor_email     String
  status          DeletionJobStatus @default(ANALYZED)
  dry_run_payload Json
  dry_run_hash    String
  environment     String
  created_at      DateTime          @default(now())
  executed_at     DateTime?

  @@index([company_id])
  @@index([status])
}

model RawIntegrationPayload {
  id              String   @id @default(uuid())
  idempotency_key String   @unique
  trace_id        String?  @default(uuid()) // For SRE Observability Tracking
  source_id       String // "ALOHA_WEBHOOK"
  store_id        String? // Might be nested in JSON, but good to index if known
  raw_json        Json
  status          String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  created_at      DateTime @default(now())

  @@index([source_id, status])
  @@index([trace_id])
}

model CanonicalEvent {
  id              String    @id @default(uuid())
  payload_id      String    @unique
  store_id        String
  event_type      String // "SalesSummaryReceived"
  normalized_data Json
  processed_at    DateTime? @default(now())
}

enum BoxStatus {
  RECEIVED
  IN_COOLER
  PULLED_TO_PREP
  CONSUMED
  WASTE
  QUARANTINED
  ADJUSTED
}

enum BoxEvent {
  RECEIVE
  PUT_AWAY
  PULL_TO_PREP
  PREP_FINISHED
  CONSUME
  MARK_WASTE
  ADMIN_ADJUST
  QUARANTINE_LOCKED
}

model ProteinBox {
  id                      String    @id @default(uuid())
  tenant_id               Int       
  store_id                Int       
  barcode                 String    
  gtin                    String?   
  lot_code                String?   
  product_name            String    
  vendor                  String?   
  
  received_weight_lb      Float
  available_weight_lb     Float     
  
  status                  BoxStatus @default(RECEIVED)
  
  received_at             DateTime  @default(now())
  received_by             String    
  
  source_receiving_event  String?   
  business_date           DateTime? 
  
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  events                  BoxLifecycleEvent[]

  @@unique([store_id, barcode, business_date]) 
  @@index([store_id, status])
  @@index([gtin, lot_code])
}

model BoxLifecycleEvent {
  id              String    @id @default(uuid())
  box_id          String
  store_id        Int
  event_type      BoxEvent  
  previous_status BoxStatus
  new_status      BoxStatus
  
  triggered_by    String    
  timestamp       DateTime  @default(now())
  
  weight_variance Float?    
  reason          String?   

  box             ProteinBox @relation(fields: [box_id], references: [id])
}

model WeeklyReconciliationSnapshot {
  id              String    @id @default(uuid())
  store_id        Int
  business_date   DateTime
  scanned_boxes   String[]  
  missing_boxes   String[]  
  total_variance_lb Float

  submitted_by    String
  created_at      DateTime  @default(now())
}

model MigrationGuardAuditLog {
  id             String    @id @default(uuid())
  created_at     DateTime  @default(now())
  guard_version  String
  boot_id        String
  environment    String
  migration_name String?
  event          String
  state_detected String?
  decision       String?
  checksum_db    String?
  checksum_local String?
  finished_at    DateTime?
  rolled_back_at DateTime?
  reason         String?
  details        Json?
}

// Enterprise SRE & Billing Enums and Models
enum TierLevel {
  TIER_1
  TIER_2
  TIER_3
}

enum DocuSignStatus {
  PENDING
  SENT
  DELIVERED
  SIGNED
  DECLINED
  VOIDED
}

model Subscription {
  id                       String    @id @default(uuid())
  organization_id          String
  stripe_subscription_id   String    @unique
  tier                     TierLevel
  price_per_store          Float
  platform_fee             Float
  store_count              Int       @default(0)
  billing_cycle            String    @default("monthly")
  status                   String    @default("active")
  
  company                  Company   @relation(fields: [organization_id], references: [id])
}

model BillingPlan {
  id                       String    @id @default(uuid())
  tier                     TierLevel @unique
  price_per_store          Float
  platform_fee             Float
  min_store_commitment     Int       @default(1)
  annual_discount_pct      Float     @default(0.0)
  created_at               DateTime  @default(now())
}
