{
    "name": "meat-tracker-server",
    "version": "2.5.2",
    "description": "Backend for Brasa Meat Tracker",
    "main": "dist/src/index.js",
    "types": "dist/src/index.d.ts",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "start": "node dist/src/scripts/resolveAllMigrations.js && PRISMA_HIDE_UPDATE_MESSAGE=true npx prisma migrate deploy && node dist/src/scripts/runMigrationGuard.js && node dist/src/index.js",
        "start:api": "node dist/src/index.js",
        "start:worker": "node dist/src/workers/index.js",
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "db:seed": "ts-node scripts/seed_targets.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1025.0",
        "@aws-sdk/s3-request-presigner": "^3.1025.0",
        "@paypal/payouts-sdk": "^1.1.1",
        "@prisma/client": "^5.22.0",
        "bcrypt": "^6.0.0",
        "bcryptjs": "^3.0.3",
        "bullmq": "^5.73.0",
        "cors": "^2.8.5",
        "csv-parse": "^6.1.0",
        "date-fns": "^4.1.0",
        "docusign-esign": "^8.6.0",
        "dotenv": "^16.4.1",
        "express": "^4.18.2",
        "express-rate-limit": "^8.3.2",
        "heic-convert": "^2.1.0",
        "helmet": "^7.1.0",
        "imap-simple": "^5.1.0",
        "ioredis": "^5.10.1",
        "ioredis-mock": "^8.13.1",
        "jsonwebtoken": "^9.0.3",
        "mailparser": "^3.9.3",
        "morgan": "^1.10.0",
        "multer": "^2.0.2",
        "node-cron": "^4.2.1",
        "node-fetch": "^2.7.0",
        "nodemailer": "^8.0.1",
        "openai": "^6.25.0",
        "pdf-parse": "^1.1.4",
        "puppeteer": "^24.39.0",
        "rate-limit-redis": "^4.3.1",
        "sharp": "^0.34.5",
        "stripe": "^20.4.1",
        "winston": "^3.19.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/docusign-esign": "^5.19.9",
        "@types/express": "^4.17.21",
        "@types/express-rate-limit": "^5.1.3",
        "@types/imap-simple": "^4.2.10",
        "@types/ioredis": "^4.28.10",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mailparser": "^3.4.6",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^2.0.0",
        "@types/node": "^20.11.16",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^7.0.11",
        "@types/paypal__payouts-sdk": "^1.0.6",
        "@types/pdf-parse": "^1.1.5",
        "@types/supertest": "^7.2.0",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "eslint": "^8.57.1",
        "jest": "^30.3.0",
        "prisma": "^5.22.0",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.9",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    },
    "prisma": {
        "seed": "node prisma/seed.js"
    }
}
